# Intersphinx mapping. cuda.core symbols (Buffer, Device, Stream,
# cuda.core.typing.IsStreamType) appear in nccl4py type annotations but
# cuda.core is mocked in autodoc_mock_imports, so they have no entry in
# our local Python domain. The intersphinx inventory provides those
# entries so python_use_unqualified_type_names can resolve them and
# render short names (`Buffer` instead of `cuda.core.Buffer`).
intersphinx_mapping = {
    'cuda-core': ('https://nvidia.github.io/cuda-python/cuda-core/latest/', None),
}

