# -- Autodoc / Napoleon configuration ----------------------------------------
# Used by the nccl4py (Python) API reference. The C-side rst pages remain
# hand-written with .. c:function:: directives.

autodoc_mock_imports = [
    'cupy',
    'torch',
    'cuda',
    'numpy',
    'packaging',
    'nccl.bindings',
]

# Default options applied to every autodoc directive unless overridden.
# Members are opt-in: rst pages add `:members:` explicitly on classes whose
# methods/properties should be documented inline. The Communicator class
# documents each method as its own section instead, so it deliberately omits
# `:members:`.
autodoc_default_options = {
    'undoc-members': False,
    'show-inheritance': True,
    'member-order': 'bysource',
}

# Render type hints from the signature, not as a separate field.
autodoc_typehints = 'signature'

# Drop fully-qualified module prefixes from type-hint rendering. Without
# this, return types like `list[Communicator]` are rendered as
# `list[nccl.core.communicator.Communicator]` and `tuple[..., NcclDataType,
# ...]` becomes `tuple[..., nccl.core.typing.NcclDataType, ...]`. With it,
# Sphinx resolves the short name against the documented Python domain.
# Note: types from mocked modules (cuda.core, cuda.core.typing) still
# render fully-qualified because they have no Python-domain entry to
# resolve against.
python_use_unqualified_type_names = True

# Napoleon: Google-style docstrings (NumPy-style is disabled).
napoleon_google_docstring = True
napoleon_numpy_docstring = False
napoleon_include_init_with_doc = False
napoleon_include_private_with_doc = False
napoleon_include_special_with_doc = False
napoleon_use_admonition_for_notes = False
napoleon_use_admonition_for_examples = False
napoleon_use_admonition_for_references = False
napoleon_use_ivar = False
napoleon_use_param = True
napoleon_use_rtype = False
# Disabled so dataclass-style classes (e.g. WaitSignalDesc) don't render a
# redundant `Type: int` block under each Attributes entry. The constructor
# signature already shows the same type info.
napoleon_attr_annotations = False


